# Automation Readiness Scorecard (Typeform/Tally/etc)
# Primary CTA links here when set
NEXT_PUBLIC_SCORECARD_URL=

# MailerLite API (server-side only — never expose to the client)
MAILERLITE_API_KEY=              # Your MailerLite API key (Settings > Integrations > API)
MAILERLITE_GROUP_ID=             # The subscriber group/list to add audit respondents to

# MailerLite newsletter embed
# NEXT_PUBLIC_MAILERLITE_FORM_ID=          # e.g. "abc123" from MailerLite > Forms > Embed
# NEXT_PUBLIC_MAILERLITE_LANDING_URL=      # fallback signup landing page URL

# Optional: Cal.com, Analytics, Contentful, etc.
# NEXT_PUBLIC_CALCOM_API_KEY=
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
